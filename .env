import json
import re
from typing import List, Dict

import fitz
import faiss
import numpy as np
import requests


OLLAMA_BASE_URL = "http://localhost:11434"
CHAT_MODEL = "qwen2.5:7b"
EMBED_MODEL = "mxbai-embed-large"   # можно заменить на all-minilm

INDEX_PATH = "storage/index.faiss"
CHUNKS_PATH = "storage/chunks.json"


def normalize_text(text: str) -> str:
    text = text.replace("\xa0", " ")
    text = re.sub(r"[ \t]+", " ", text)
    text = re.sub(r"\n{3,}", "\n\n", text)
    return text.strip()


def extract_pages_from_pdf(pdf_path: str) -> List[Dict]:
    doc = fitz.open(pdf_path)
    pages = []

    for i, page in enumerate(doc):
        text = page.get_text("text")
        text = normalize_text(text)
        if text:
            pages.append({
                "page": i + 1,
                "text": text,
            })

    return pages


def split_into_chunks(
    pages: List[Dict],
    chunk_size: int = 900,
    overlap: int = 150
) -> List[Dict]:
    chunks = []
    chunk_id = 0

    for page_item in pages:
        page_num = page_item["page"]
        text = page_item["text"]

        start = 0
        while start < len(text):
            end = start + chunk_size
            chunk_text = text[start:end].strip()

            if chunk_text:
                chunks.append({
                    "chunk_id": chunk_id,
                    "page": page_num,
                    "text": chunk_text,
                })
                chunk_id += 1

            if end >= len(text):
                break

            start = end - overlap

    return chunks


def ollama_embed(texts: List[str], model: str = EMBED_MODEL) -> np.ndarray:
    vectors = []

    for text in texts:
        response = requests.post(
            f"{OLLAMA_BASE_URL}/api/embed",
            json={
                "model": model,
                "input": text
            },
            timeout=120
        )
        response.raise_for_status()
        data = response.json()

        # Ollama обычно возвращает embeddings списком
        embedding = data["embeddings"][0]
        vectors.append(embedding)

    arr = np.array(vectors, dtype="float32")

    # нормализация для cosine / inner product
    norms = np.linalg.norm(arr, axis=1, keepdims=True)
    arr = arr / np.clip(norms, 1e-12, None)

    return arr.astype("float32")


def save_chunks(chunks: List[Dict], path: str = CHUNKS_PATH):
    with open(path, "w", encoding="utf-8") as f:
        json.dump(chunks, f, ensure_ascii=False, indent=2)


def load_chunks(path: str = CHUNKS_PATH) -> List[Dict]:
    with open(path, "r", encoding="utf-8") as f:
        return json.load(f)


def save_faiss_index(vectors: np.ndarray, path: str = INDEX_PATH):
    dim = vectors.shape[1]
    index = faiss.IndexFlatIP(dim)
    index.add(vectors)
    faiss.write_index(index, path)


def load_faiss_index(path: str = INDEX_PATH):
    return faiss.read_index(path)


class Retriever:
    def __init__(self):
        self.index = load_faiss_index()
        self.chunks = load_chunks()

    def search(self, query: str, top_k: int = 4) -> List[Dict]:
        q_vec = ollama_embed([query])
        scores, indices = self.index.search(q_vec, top_k)

        results = []
        for score, idx in zip(scores[0], indices[0]):
            if idx == -1:
                continue

            chunk = self.chunks[idx]
            results.append({
                "chunk_id": chunk["chunk_id"],
                "page": chunk["page"],
                "text": chunk["text"],
                "score": float(score),
            })

        return results


def filter_chunks(chunks: List[Dict], min_score: float = 0.35) -> List[Dict]:
    return [c for c in chunks if c["score"] >= min_score]


class Generator:
    @staticmethod
    def build_context(chunks: List[Dict]) -> str:
        parts = []
        for i, chunk in enumerate(chunks, start=1):
            parts.append(
                f"[Фрагмент {i} | стр. {chunk['page']}]\n{chunk['text']}"
            )
        return "\n\n".join(parts)

    def answer(self, question: str, chunks: List[Dict]) -> str:
        context = self.build_context(chunks)

        prompt = f"""
Ты отвечаешь строго по предоставленному контексту из одного документа.
Нельзя использовать внешние знания.
Если ответа в контексте нет, ответь: "В документе это не найдено."
Отвечай кратко, максимум 2-3 предложения, без воды.

Вопрос:
{question}

Контекст:
{context}

Краткий ответ:
""".strip()

        response = requests.post(
            f"{OLLAMA_BASE_URL}/api/generate",
            json={
                "model": CHAT_MODEL,
                "prompt": prompt,
                "stream": False
            },
            timeout=180
        )
        response.raise_for_status()
        return response.json()["response"].strip()